---
import "hotkeypad/reset.css";
import "hotkeypad/index.css";
import { buildProfilesInfo } from "@/lib/keyboard-manager";
import { type Profile } from "@/types";
import { Icon } from "astro-icon/components";

interface Props {
  profiles: Profile[];
  lang: string;
}
const { lang, profiles } = Astro.props;
const profilesInfo = buildProfilesInfo(profiles, lang);
---

<footer
  id="normal-footer"
  class="flex flex-col gap-2 font-mono theme-blackwhite:text-skin-inverted"
>
  <div>
    {lang == "en" ? "Press" : "Presiona"}
    <kbd class="theme-blackwhite:text-skin-base">Cmd</kbd> + <kbd
      class="theme-blackwhite:text-skin-base">K</kbd
    >
    {
      lang == "en"
        ? "to open the command palette."
        : "para abrir la paleta de comandos."
    }
  </div>
</footer>
<button
  type="button"
  class="footer-button z-20 border border-skin-muted/60 bg-skin-fill text-skin-hue transition-colors duration-200 ease-linear theme-blackwhite:border-skin-muted"
  aria-label={lang == "en" ? "Open command palette" : "Abrir paleta de comandos"}
>
  <Icon
    name="ri:command-fill"
    width={20}
    height={20}
    class="text-skin-hue theme-blackwhite:dark:text-skin-inverted"
    aria-hidden="true"
  />
</button>

<div
  id="hotkeypad"
  data-placeholder={lang == "en" ? "Search..." : "Buscar..."}
  data-info={JSON.stringify(profilesInfo)}
  data-lang={lang}
>
</div>

<script>
  import {
    createKeyboardCommands,
    dispatchCommandPaletteShortcut,
  } from "@/lib/keyboard-manager";
  import HotKeyPad from "hotkeypad";

  const hotkeypad = new HotKeyPad();
  const info = hotkeypad.instance.getAttribute("data-info") ?? "[]";
  const lang = hotkeypad.instance.getAttribute("data-lang") ?? "en";
  const parsedInfo = JSON.parse(info);
  hotkeypad.setCommands(
    createKeyboardCommands(parsedInfo, lang, (url, target) => {
      window.open(url, target);
    })
  );

  const footerButtons = document.querySelectorAll(".footer-button");
  footerButtons.forEach((button) => {
    button.addEventListener("click", () => {
      dispatchCommandPaletteShortcut(document, KeyboardEvent);
    });
  });

  document.addEventListener("DOMContentLoaded", () => {
    const backdrop = document.querySelector(
      "#hotkeypad [data-backdrop]"
    ) as HTMLDivElement;
    window.addEventListener("hotkeypad:open", () => {
      backdrop.style.opacity = "0.8";
    });
    window.addEventListener("hotkeypad:close", () => {
      backdrop.style.opacity = "0";
    });
  });
</script>

<style>
  @media (min-width: 601px) {
    .footer-button {
      display: none;
    }
  }

  @media (max-width: 600px) {
    #normal-footer {
      display: none;
    }

    .footer-button {
      appearance: none;
      border-radius: 50%;
      bottom: 10px;
      display: flex;
      align-items: center;
      cursor: pointer;
      height: 50px;
      justify-content: center;
      padding: 0;
      position: fixed;
      right: 10px;
      width: 50px;
    }
  }

  #normal-footer {
    @apply bg-skin-button-accent;
    position: fixed;
    bottom: 0px;
    width: 100%;
    padding-block: 8px;
    text-align: center;
    font-size: 0.85rem;
    transition:
      background-color 0.2s ease,
      color 0.2s ease,
      border-color 0.2s ease;
  }
  kbd {
    @apply bg-skin-muted;
    border-radius: 4px;
    padding: 2px 4px;
    font-size: 12px;
  }
  #hotkeypad {
    --hotkeypad-bg-kbd: rgb(var(--muted));
    --hotkeypad-bg-backdrop: rgb(var(--muted));
    --hotkeypad-bg-container: rgb(var(--color-fill));
    --hotkeypad-bg-item-hover: rgba(var(--color-text), 20%);
    --hotkeypad-border-container: rgb(var(--muted));
    --hotkeypad-border-container-hover: rgb(var(--color-fill));
    --hotkeypad-fg-muted: rgb(var(--color-text-base));
    @media (prefers-color-scheme: dark) {
      --hotkeypad-bg-kbd: rgb(var(--muted));
      --hotkeypad-bg-backdrop: rgb(var(--muted));
      --hotkeypad-bg-container: rgb(var(--color-fill));
      --hotkeypad-bg-item-hover: rgba(var(--color), 10%);
      --hotkeypad-border-container: rgb(var(--muted));
      --hotkeypad-border-container-hover: rgb(var(--color-fill));
      --hotkeypad-fg-muted: rgb(var(--color-text-base));
    }
  }
</style>
